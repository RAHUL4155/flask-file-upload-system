{
  "rules": [
    {
      "condition": "always",
      "commandType": "vscode",
      "command": "studio-manager.openFile app.py 1"
    },
    {
      "condition": "always",
      "commandType": "vscode",
      "command": "studio-manager.openSimpleBrowser https://${STUDIO_HOST_ID}-5000.${STUDIO_HOST}",
      "delay": 2000
    },
    {
      "condition": "always",
      "commandType": "vscode",
      "command": "studio-manager.openTerminal",
      "cmdArgs": [
        "flask --app app.py run --host=0.0.0.0 --port=5000 --debug",
        {
          "name": "flask",
          "location": 1
        }
      ],
      "delay": 500
    }
  ],
  "simpleBrowserDefaultAppUrl": "https://${STUDIO_HOST_ID}-5000.${STUDIO_HOST}"
}